# Servidor
NODE_ENV=production
PORT=3333

# Autenticação (obrigatório em produção)
JWT_SECRET="sua-chave-secreta-longa-e-segura"

# Banco MySQL
# Se o MySQL estiver na MESMA VPS que o backend, use localhost:
DATABASE_URL="mysql://USUARIO:SENHA@localhost:3306/NOME_DO_BANCO"

# Exemplo (banco na própria VPS):
# DATABASE_URL="mysql://lucas:MinHaS3nh4@localhost:3306/agendatoss"
# Exemplo (banco em outro host):
# DATABASE_URL="mysql://u123456789_agenda:Su4S3nh4@mysql.hostinger.com:3306/u123456789_agenda"
